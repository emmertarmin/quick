---
import GithubSlugger from "github-slugger";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  function stripMarkdown(text: string) {
    return text
      .replace(/`([^`]+)`/g, "$1")
      .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
      .replace(/[*_~]/g, "")
      .trim();
  }

  function extractHeadings(markdown: string) {
    const slugger = new GithubSlugger();
    let inFence = false;
    const headings = [];

    for (const line of markdown.split("\n")) {
      if (/^\s*```/.test(line)) {
        inFence = !inFence;
        continue;
      }

      if (inFence) continue;

      const match = /^(#{1,3})\s+(.+?)\s*#*\s*$/.exec(line);
      if (!match) continue;

      const depth = match[1].length;
      const text = stripMarkdown(match[2]);
      headings.push({ depth, text, slug: slugger.slug(text) });
    }

    return headings;
  }
  const docModules = import.meta.glob("../../../../../docs/**/*.md");
  const rawDocModules = import.meta.glob("../../../../../docs/**/*.md", { query: "?raw", import: "default" });
  const docs = await Promise.all(
    Object.entries(docModules).map(async ([file, load]) => ({
      file,
      markdown: await rawDocModules[file]?.(),
      ...await load(),
    })),
  );

  return docs.map((entry) => {
    const slug = entry.file.split("/docs/").at(-1)?.replace(/\.md$/, "") ?? "";
    return {
      params: { slug: slug === "index" ? undefined : slug },
      props: { entry, headings: extractHeadings(entry.markdown ?? "") },
    };
  });
}

const { entry, headings: allHeadings } = Astro.props;
const { Content } = entry;
const fileSlug = entry.file.split("/docs/").at(-1)?.replace(/\.md$/, "") ?? "";
const slug = fileSlug === "index" ? "" : fileSlug;
const title = entry.frontmatter.title || allHeadings.find((heading) => heading.depth === 1)?.text || fileSlug;
const headings = allHeadings.filter((heading) => heading.depth > 1 && heading.depth <= 3);
const crumbs = slug
  ? slug.split("/").map((part, index, parts) => ({
    label: part.replace(/-/g, " "),
    href: `/docs/${parts.slice(0, index + 1).join("/")}/`,
  }))
  : [];
---

<Layout title={`${title} · Quick docs`}>
  <main class="doc-shell">
    <aside class="sidebar" aria-label="Page navigation">
      <nav class="breadcrumbs" aria-label="Breadcrumbs">
        <a href="/docs/">Docs</a>
        {crumbs.map((crumb, index) => (
          <>
            <span aria-hidden="true">/</span>
            {index === crumbs.length - 1 ? <span>{crumb.label}</span> : <a href={crumb.href}>{crumb.label}</a>}
          </>
        ))}
      </nav>

      {headings.length > 0 && (
        <nav class="toc" aria-label="Table of contents">
          <strong>On this page</strong>
          <ol>
            {headings.map((heading) => (
              <li class={`depth-${heading.depth}`}><a href={`#${heading.slug}`}>{heading.text}</a></li>
            ))}
          </ol>
        </nav>
      )}
    </aside>

    <article class="prose">
      <Content />
    </article>
  </main>
</Layout>

<style>
  .doc-shell {
    display: grid;
    grid-template-columns: minmax(12rem, 18rem) minmax(0, 46rem);
    gap: 4rem;
    width: min(76rem, calc(100% - 4rem));
    margin: 0 auto;
    padding: 3rem 0 5rem;
  }

  .sidebar {
    position: sticky;
    top: 2rem;
    align-self: start;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2rem;
    text-transform: capitalize;
  }

  .toc {
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }

  .toc strong {
    display: block;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .toc ol {
    display: grid;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .toc .depth-3 {
    padding-left: 1rem;
  }

  .prose {
    min-width: 0;
    line-height: 1.75;
  }

  .prose :global(h1) {
    margin: 0 0 2rem;
    font-size: clamp(2.2rem, 6vw, 4rem);
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .prose :global(h2) {
    margin: 2.5rem 0 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 1.65rem;
    letter-spacing: -0.02em;
  }

  .prose :global(h3) {
    margin: 2rem 0 0.75rem;
    font-size: 1.2rem;
  }

  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol) {
    margin: 1rem 0;
  }

  .prose :global(li + li) {
    margin-top: 0.35rem;
  }

  .prose :global(.code-title) {
    display: inline-flex;
    align-items: center;
    margin: 1.25rem 0 0;
    border: 1px solid var(--border);
    border-bottom: 0;
    border-radius: 0.75rem 0.75rem 0 0;
    padding: 0.35rem 0.75rem;
    background: var(--code-bg);
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 0.8rem;
  }

  .prose :global(.code-title + pre) {
    margin-top: 0;
    border-top-left-radius: 0;
  }

  .prose :global(pre) {
    overflow-x: auto;
    margin: 1rem 0;
    padding: 1rem;
    border-radius: 0.75rem;
    background: var(--code-bg);
  }

  .prose :global(code) {
    border-radius: 0.3rem;
    padding: 0.1rem 0.25rem;
    background: var(--code-bg);
    font-size: 0.92em;
  }

  .prose :global(pre code) {
    padding: 0;
    background: transparent;
  }

  .prose :global(blockquote) {
    margin: 1.5rem 0;
    padding-left: 1rem;
    border-left: 3px solid var(--border);
    color: var(--muted);
  }

  .prose :global(table) {
    display: block;
    overflow-x: auto;
    border-collapse: collapse;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border);
  }

  @media (max-width: 900px) {
    .doc-shell {
      grid-template-columns: 1fr;
      gap: 2rem;
      width: min(100% - 2rem, 76rem);
      padding-top: 2rem;
    }

    .sidebar {
      position: static;
    }
  }
</style>
