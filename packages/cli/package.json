{
  "name": "@emmertarmin/quick",
  "version": "0.1.1",
  "description": "Command line tools for self-hosted Quick sites.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Armin Emmert",
    "email": "emmertarmin@gmail.com"
  },
  "homepage": "https://github.com/emmertarmin/quick",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emmertarmin/quick.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/emmertarmin/quick/issues"
  },
  "bin": {
    "quick": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "rm -rf dist && bun build ./src/index.ts --outfile dist/index.js --target bun",
    "tsc": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "prepack": "bun run build",
    "prepublishOnly": "bun run tsc && bun test"
  },
  "devDependencies": {
    "@openauthjs/openauth": "^0.4.3",
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
