QUICK_DOMAIN=local.example.com

# Development code login is enabled by default. Set to true to suppress it.
QUICK_AUTH_DISABLE_CODE=false

# Optional Microsoft Entra ID login. Set client ID and secret together to enable it.
# QUICK_ENTRA_TENANT_ID may be a tenant GUID, "organizations", or "common" (default).
QUICK_ENTRA_TENANT_ID=
QUICK_ENTRA_CLIENT_ID=
QUICK_ENTRA_CLIENT_SECRET=

CLOUDFLARE_API_TOKEN=
ACME_EMAIL=
